# Frontend – Supabase (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Opcionális: Edge Functions alap URL (alapból: VITE_SUPABASE_URL + /functions/v1)
# VITE_SUPABASE_FUNCTION_URL=https://<project-ref>.supabase.co/functions/v1

# Lokál fejlesztés: callback ne adminai.hu-ra menjen. Állítsd be és Supabase Dashboard →
# Authentication → URL Configuration → Redirect URLs: add http://localhost:8083/auth/callback
# VITE_APP_ORIGIN=http://localhost:8083
