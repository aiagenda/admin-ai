# Frontend – Supabase (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Opcionális: Edge Functions alap URL (alapból: VITE_SUPABASE_URL + /functions/v1)
# VITE_SUPABASE_FUNCTION_URL=https://<project-ref>.supabase.co/functions/v1

# Lokál fejlesztés (pl. npm run dev -- --port 5173): callback localhostra menjen.
# Másold ezt .env.local-ba és állítsd be. Supabase Dashboard → Authentication →
# URL Configuration → Redirect URLs: add http://localhost:5173/auth/callback
VITE_APP_ORIGIN=http://localhost:5173

# Könyvelés modul: alapból minden bejelentkezett user elérheti (tesztelés). Korlátozás: VITE_INVOICE_ACCESS_FOR_ALL=false
# VITE_INVOICE_ACCESS_FOR_ALL=false

# Vercel (Edge middleware): előnézeti jelszó a teljes oldalhoz. HTTP Basic Auth: bármilyen felhasználónév + ez a jelszó.
# SITE_ACCESS_PASSWORD=

# Stripe (Supabase Edge: create-checkout-session, stripe-webhook + Stripe Dashboard products)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_BASIC_DOC=
# STRIPE_PRICE_PRO_DOC=
# STRIPE_PRICE_MONTHLY=
# STRIPE_PRICE_BUSINESS=
# STRIPE_PRICE_ENTERPRISE=
# Hátralévő aliasok: STRIPE_PRICE_ALAP (havi), STRIPE_PRICE_PRO (Professzionális / enterprise)
# APP_URL=https://your-app.vercel.app

# Publikus URL (canonical, OG) — prod: https://adminai.hu
# VITE_PUBLIC_SITE_URL=https://adminai.hu
