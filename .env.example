# ─────────────────────────────────────────────────
#  Market / Brand
# ─────────────────────────────────────────────────
# us = English-only UI + IRS/federal analysis (GovLetter)
# hu = bilingual Hungarian launch (GovLetter)
VITE_MARKET=us

# ─────────────────────────────────────────────────
#  Supabase  ← REQUIRED — app won't start without these
# ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>
# Optional override — defaults to VITE_SUPABASE_URL/functions/v1
# VITE_SUPABASE_FUNCTION_URL=

# ─────────────────────────────────────────────────
#  Site / SEO
# ─────────────────────────────────────────────────
# Canonical domain — used for OG image, sitemap, canonical links
# US:  https://govletter.com  (or .com when registered)
# HU:  https://govletter.com
VITE_PUBLIC_SITE_URL=https://govletter.com

# Used in some places as the app's own origin (CORS, deeplinks)
# Usually same as VITE_PUBLIC_SITE_URL
VITE_APP_ORIGIN=https://govletter.com

# ─────────────────────────────────────────────────
#  Legal / Imprint  (shown on /legal/imprint)
# ─────────────────────────────────────────────────
VITE_LEGAL_ENTITY_NAME=
VITE_LEGAL_REGISTERED_ADDRESS=
VITE_LEGAL_PRIVACY_EMAIL=
VITE_LEGAL_SUPPORT_EMAIL=
VITE_LEGAL_SECURITY_EMAIL=

# ─────────────────────────────────────────────────
#  Feature flags
# ─────────────────────────────────────────────────
# Set to "true" to enforce per-user upload limits (recommended in production)
VITE_USAGE_LIMIT_ENABLED=true

# Set to "true" to open the invoice module to all users (not just admins)
VITE_INVOICE_ACCESS_FOR_ALL=false

# ─────────────────────────────────────────────────
#  Admin / Owner access
# ─────────────────────────────────────────────────
# Comma-separated list of email addresses that have owner-level access
# Example: admin@example.com,owner@example.com
VITE_OWNER_EMAILS=

# ─────────────────────────────────────────────────
#  Push notifications (Web Push / VAPID)
# ─────────────────────────────────────────────────
# The PUBLIC VAPID key — safe to expose in the browser
# Generate a key pair: npx web-push generate-vapid-keys
# The PRIVATE key goes in Supabase Edge Function secrets only!
VITE_VAPID_PUBLIC_KEY=

# ─────────────────────────────────────────────────
#  Staging / Preview access protection
# ─────────────────────────────────────────────────
# Leave unset on public production domains (SEO + sign-up will break).
# Set on preview/staging branches to password-protect the entire site.
# SITE_ACCESS_PASSWORD=

# ─────────────────────────────────────────────────
#  Edge Function secrets  (Supabase Dashboard → Settings → Edge Functions → Secrets)
#  These are NOT set in .env — they live server-side only.
#  Documented here for reference:
# ─────────────────────────────────────────────────
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_BASIC_DOC=
# STRIPE_PRICE_PRO_DOC=
# STRIPE_PRICE_MONTHLY=
# STRIPE_PRICE_BUSINESS=
# STRIPE_PRICE_ENTERPRISE=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# VAPID_PRIVATE_KEY=
